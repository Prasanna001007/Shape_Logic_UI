<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CANVAS SCREEN -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/screenCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAFAFA"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvLetter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="100sp"
            android:textColor="#DDDDDD"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvRoundInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Round 1 of 3"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.example.guesstheobject.ui.DrawingView
            android:id="@+id/learnDrawView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/canvas_border"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvLetter"
            app:layout_constraintBottom_toTopOf="@id/btnLearnClear"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnLearnClear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="Clear"
            android:backgroundTint="#C0392B"
            android:textColor="#FFFFFF"
            android:layout_margin="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RESULT SCREEN -->
    <ScrollView
        android:id="@+id/screenResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAFAFA"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="72sp"
                android:layout_marginTop="24dp"/>

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You finished all letters!"
                android:textSize="24sp"
                android:textColor="#333333"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvOverallScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overall Score: 85%"
                android:textSize="36sp"
                android:textColor="#E8A87C"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvScoreMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Great job! Keep it up!"
                android:textSize="16sp"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⭐ Letters you are good at:"
                android:textSize="16sp"
                android:textColor="#333333"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvGoodLetters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A, B, C"
                android:textSize="22sp"
                android:textColor="#4CAF50"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📝 Letters to focus on:"
                android:textSize="16sp"
                android:textColor="#333333"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvFocusLetters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="D, E, F"
                android:textSize="22sp"
                android:textColor="#E8593C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnTryAgain"
                android:layout_width="260dp"
                android:layout_height="56dp"
                android:text="Try Again! 🔄"
                android:textSize="16sp"
                android:backgroundTint="#7CB9E8"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnBackToMenu"
                android:layout_width="260dp"
                android:layout_height="56dp"
                android:text="Back to Menu"
                android:textSize="16sp"
                android:backgroundTint="#CCCCCC"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </ScrollView>

</FrameLayout>