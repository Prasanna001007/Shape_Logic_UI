<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/white">
    <!--  Current letter (large, faint, top center)  -->
    <TextView android:id="@+id/tvLetter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A" android:textSize="100sp"
        android:textColor="#E0E0E0"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>
    <!--  Round info — top right  -->

    <TextView android:id="@+id/tvRoundInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Round 1 of 3"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--  Drawing canvas — center, 70% height  -->
    <com.example.guesstheobject.ui.DrawingView
        android:id="@+id/learnDrawView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/canvas_border"
        app:layout_constraintTop_toBottomOf="@id/tvLetter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnLearnClear"
        app:layout_constraintHeight_percent="0.65"/>

    <!--  Clear button — bottom  -->
    <Button
        android:id="@+id/btnLearnClear"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="🗑️ Clear"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#EF5350"
        android:layout_margin="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>