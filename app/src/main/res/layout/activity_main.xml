<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= LOADING SCREEN ================= -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/loadingImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/shapelogicloadingscreennew"
            android:scaleType="fitCenter"
            android:contentDescription="Loading background"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="48dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI is thinking…"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp"
                android:gravity="center"/>

            <ProgressBar
                android:id="@+id/loadingProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="220dp"
                android:layout_height="6dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ================= MAIN MENU SCREEN ================= -->
    <FrameLayout
        android:id="@+id/mainMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Background for main menu -->
        <ImageView
            android:id="@+id/menuBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/homepage"
            android:scaleType="centerCrop"
            android:contentDescription="Main menu background"/>

        <!-- Buttons centered over background -->
        <LinearLayout
            android:id="@+id/modeButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="24dp">

            <Button
                android:id="@+id/btnAkinatorMode"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Akinator Mode"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="@drawable/button_background"
                android:layout_marginBottom="16dp"
                android:padding="12dp"
                android:elevation="8dp"/>

            <!-- Drawing Mode Button -->
            <Button
                android:id="@+id/btnDrawingMode"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Drawing Mode"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="@drawable/button_background"
                android:padding="12dp"
                android:elevation="8dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/flFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
