<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/white">
    <!--  ═══════════════════════════════════════════════════
             SCREEN 1 — FREE MODE CANVAS
             ═══════════════════════════════════════════════════  -->
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/screenFreeMode" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="visible">
        <!--  Bear icon — top left  -->
        <ImageView android:id="@+id/imgBear"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/bearthinkingpngnew"
            android:layout_margin="12dp"
            android:contentDescription="Bear"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <!--  Random bear guess text — next to bear  -->
        <TextView
            android:id="@+id/txtBearGuess"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hmm, what are you drawing? 🤔"
            android:textSize="15sp"
            android:textColor="#555555"
            android:textStyle="italic"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintTop_toTopOf="@id/imgBear"
            app:layout_constraintBottom_toBottomOf="@id/imgBear"
            app:layout_constraintStart_toEndOf="@id/imgBear"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!--  Drawing Canvas — 70% screen height  -->

        <com.example.guesstheobject.ui.DrawingView
            android:id="@+id/drawView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            android:background="@drawable/canvas_border"
            app:layout_constraintTop_toBottomOf="@id/imgBear"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/toolbar"
            app:layout_constraintHeight_percent="0.70"/>

        <!--  Toolbar  -->
        <LinearLayout android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#EEEEEE"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnSend">

            <ImageButton android:id="@+id/btnClear"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_clear"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="6dp" android:contentDescription="Clear"/>

            <ImageButton
                android:id="@+id/btnEraser"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_eraser"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="6dp"
                android:contentDescription="Eraser"/>

            <ImageButton
                android:id="@+id/btnColor"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_color"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="6dp" android:contentDescription="Color"/>

            <ImageButton
                android:id="@+id/btnWidth"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_pencil"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="6dp"
                android:contentDescription="Stroke width"/>

        </LinearLayout>

        <!--  Guess Button  -->

        <Button
            android:id="@+id/btnSend"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="🔍 Guess!"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:backgroundTint="#03DAC5"
            android:layout_margin="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <!--  ═══════════════════════════════════════════════════
             SCREEN 2 — GUESS RESULT (full screen overlay)
             ═══════════════════════════════════════════════════  -->
    <LinearLayout
        android:id="@+id/screenGuessResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFDE7"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgResultBear"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/bearthinkingpngnew"
            android:contentDescription="Bear"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI is analysing your drawing..."
            android:textSize="16sp"
            android:textColor="#777777"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/txtGuessResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I think your drawing is a... 🌳 Tree!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <Button android:id="@+id/btnDrawAgain"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="🖌️ Draw Again"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#FF7043"/>
    </LinearLayout>
</FrameLayout>