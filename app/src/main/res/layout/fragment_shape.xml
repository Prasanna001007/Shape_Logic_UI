<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Shape name header -->
    <TextView
        android:id="@+id/tvShapeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Circle"
        android:textSize="52sp"
        android:textColor="#DDDDDD"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Round info top right -->
    <TextView
        android:id="@+id/tvShapeRoundInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Round 1 of 3"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"/>

    <!-- Shape preview (filled colored shape) -->
    <com.example.guesstheobject.ui.ShapePreviewView
        android:id="@+id/shapePreview"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:layout_constraintTop_toBottomOf="@id/tvShapeName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- Drawing canvas -->
    <com.example.guesstheobject.ui.DrawingView
        android:id="@+id/shapeDrawView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/canvas_border"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/shapePreview"
        app:layout_constraintBottom_toTopOf="@id/btnShapeClear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.55"/>

    <!-- Clear button -->
    <Button
        android:id="@+id/btnShapeClear"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Clear"
        android:backgroundTint="#C0392B"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
