<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FAFAFA">

    <Button
        android:id="@+id/btnFreeMode"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="🎨  Free Draw"
        android:textSize="18sp"
        android:backgroundTint="#E8A87C"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnLearnMode"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="🔤  Learn Letters"
        android:textSize="18sp"
        android:backgroundTint="#7CB9E8"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnShapesMode"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="⭐  Learn Shapes"
        android:textSize="18sp"
        android:backgroundTint="#A8E87C"
        android:textColor="#FFFFFF"/>

</LinearLayout>